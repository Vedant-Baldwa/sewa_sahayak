# Backend Environment Variables — FastAPI / Boto3
# Copy this file to backend/.env and fill in the values before running uvicorn.
# Never commit the real .env file — it is gitignored.

# ------------------------------------------------------------------
# AWS Core
# ------------------------------------------------------------------
# Region where all AWS services (S3, DynamoDB, Bedrock, etc.) are provisioned.
AWS_REGION=ap-south-1

# IAM credentials — only needed for local development.
# In production (EC2) use an IAM Role attached to the instance instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Region for Amazon Bedrock (Nova models are us-east-1 or us-west-2)
BEDROCK_REGION=us-east-1

# ------------------------------------------------------------------
# Amazon S3
# ------------------------------------------------------------------
# Bucket used to store uploaded evidence (images, audio, video clips).
S3_BUCKET_NAME=

# ------------------------------------------------------------------
# Amazon DynamoDB
# ------------------------------------------------------------------
# Table that stores filed complaint reports (partition key: ticketId).
DYNAMODB_TABLE=sewa_sahayak_reports

# Table that stores user profile records (partition key: userId).
USERS_TABLE_NAME=sewa_sahayak_users

# ------------------------------------------------------------------
# Session Security
# ------------------------------------------------------------------
# A strong, random string (minimum 32 characters) used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ------------------------------------------------------------------
# App URLs
# ------------------------------------------------------------------
# Full URL of the React frontend (used for OAuth redirect targets).
# Local dev:  http://localhost:5173
# Production: http://your-ec2-domain.nip.io
FRONTEND_URL=http://localhost:5173

# Full URL of this FastAPI backend (used to build OAuth callback URLs).
# Local dev:  http://localhost:8000
# Production: http://your-ec2-domain.nip.io
BACKEND_URL=http://localhost:8000

# ------------------------------------------------------------------
# AWS Cognito (optional — omit to use mock auth for local testing)
# ------------------------------------------------------------------
# Found in AWS Console → Cognito → User Pools → your pool → Overview
COGNITO_USER_POOL_ID=

# Found in AWS Console → Cognito → User Pools → your pool → App clients
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# ------------------------------------------------------------------
# Google OAuth 2.0 (optional — omit to disable Google sign-in)
# ------------------------------------------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must include: <BACKEND_URL>/authorize/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
