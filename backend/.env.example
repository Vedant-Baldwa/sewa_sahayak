# AWS Configuration
AWS_REGION=ap-south-1

# Cognito Configuration
COGNITO_USER_POOL_ID=<your-cognito-user-pool-id>
COGNITO_CLIENT_ID=<your-cognito-app-client-id>
COGNITO_CLIENT_SECRET=<your-cognito-app-client-secret>

# DynamoDB Tables
DYNAMODB_TABLE=sewa_sahayak_reports
USERS_TABLE_NAME=sewa_sahayak_users

# S3
S3_BUCKET_NAME=<your-s3-bucket-name>

# Session Security (generate a strong random string for production)
SECRET_KEY=<your-secret-key-min-32-chars>

# App URLs (use localhost for local dev, your production domain for deployment)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS IAM Keys (use IAM roles in production; keys only for local dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
